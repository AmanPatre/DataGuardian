# DataGuardian Backend Environment Variables Template
PORT=5000
NODE_ENV=production

# MongoDB Atlas URI
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/DataGuardian

# Google Gemini API Key (Required for AI Analysis)
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Security Settings
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
